{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information for the portfolio workbench.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Messages sent via the portfolio contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Contact messages from visitors."
    }
  }
}
